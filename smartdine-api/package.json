{
  "name": "smartdine-api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:ai": "node --env-file=.env.ai ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "dev:cc": "node --env-file=.env.cc ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
